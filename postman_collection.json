		{
			"name": "Search & Suggestions",
			"item": [
				{
					"name": "Search",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/search?q=rock",
							"host": ["{{baseUrl}}"],
							"path": ["search"],
							"query": [{ "key": "q", "value": "rock" }]
						},
						"description": "Cross-entity search across songs, artists, albums, playlists"
					}
				},
				{
					"name": "Suggestions",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/suggestions?q=ba",
							"host": ["{{baseUrl}}"],
							"path": ["suggestions"],
							"query": [{ "key": "q", "value": "ba" }]
						},
						"description": "Autocomplete suggestions (min 2 chars). Returns id, name, type."
					}
				}
			]
		},
		{
			"name": "Users (me)",
