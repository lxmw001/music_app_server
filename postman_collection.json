{
	"info": {
		"name": "Music App API",
		"description": "NestJS Music API with Firebase, YouTube, and Gemini AI",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://music-app-server-lupbg4y2ha-uc.a.run.app",
			"type": "string"
		},
		{
			"key": "firebaseToken",
			"value": "",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{firebaseToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Songs",
			"item": [
				{
					"name": "List Songs",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs?page=1&pageSize=20",
							"host": ["{{baseUrl}}"],
							"path": ["songs"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "pageSize", "value": "20" }
							]
						}
					}
				},
				{
					"name": "Get Song by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/:id",
							"host": ["{{baseUrl}}"],
							"path": ["songs", ":id"],
							"variable": [{ "key": "id", "value": "" }]
						}
					}
				},
				{
					"name": "Search YouTube (simple)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/search-youtube?query=bad bunny",
							"host": ["{{baseUrl}}"],
							"path": ["songs", "search-youtube"],
							"query": [{ "key": "query", "value": "bad bunny" }]
						},
						"description": "Simple artist/song name search"
					}
				},
				{
					"name": "Search YouTube (natural language)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/search-youtube?query=sad reggaeton songs",
							"host": ["{{baseUrl}}"],
							"path": ["songs", "search-youtube"],
							"query": [{ "key": "query", "value": "sad reggaeton songs" }]
						},
						"description": "Natural language query — Gemini extracts genre/mood/tags"
					}
				},
				{
					"name": "Trending Music",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/trending?country=EC&limit=50",
							"host": ["{{baseUrl}}"],
							"path": ["songs", "trending"],
							"query": [
								{ "key": "country", "value": "EC" },
								{ "key": "limit", "value": "50" }
							]
						},
						"description": "Trending music by country code (cached 6h)"
					}
				},
				{
					"name": "All Searches",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/searches",
							"host": ["{{baseUrl}}"],
							"path": ["songs", "searches"]
						},
						"description": "Get all search queries ordered by popularity (cached in memory, updated in real-time)"
					}
				},
				{
					"name": "Generate Playlist from Song",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/:id/generate-playlist?limit=30",
							"host": ["{{baseUrl}}"],
							"path": ["songs", ":id", "generate-playlist"],
							"query": [{ "key": "limit", "value": "30" }],
							"variable": [{ "key": "id", "value": "" }]
						},
						"description": "AI-generated playlist based on a seed song (Last.fm similar tracks)"
					}
				},
				{
					"name": "Refresh Song Metadata",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/:id/refresh-metadata",
							"host": ["{{baseUrl}}"],
							"path": ["songs", ":id", "refresh-metadata"],
							"variable": [{ "key": "id", "value": "" }]
						},
						"description": "Refresh Last.fm metadata (genres, tags, album art, listeners)"
					}
				},
				{
					"name": "Get Stream URL",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/:id/stream-url",
							"host": ["{{baseUrl}}"],
							"path": ["songs", ":id", "stream-url"],
							"variable": [{ "key": "id", "value": "" }]
						},
						"description": "Get cached YouTube audio stream URL for a song. Fetches from Firestore cache (stream_url_cache) or resolves fresh from YouTube. TTL derived from expire= param in URL (~6h)."
					}
				}
			]
		},
		{
			"name": "Artists",
			"item": [
				{
					"name": "List Artists",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/artists?page=1&pageSize=20",
							"host": ["{{baseUrl}}"],
							"path": ["artists"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "pageSize", "value": "20" }
							]
						}
					}
				},
				{
					"name": "Get Artist by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/artists/:id",
							"host": ["{{baseUrl}}"],
							"path": ["artists", ":id"],
							"variable": [{ "key": "id", "value": "" }]
						}
					}
				},
				{
					"name": "Get Artist Songs",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/artists/:id/songs",
							"host": ["{{baseUrl}}"],
							"path": ["artists", ":id", "songs"],
							"variable": [{ "key": "id", "value": "" }]
						}
					}
				},
				{
					"name": "Get Artist Albums",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/artists/:id/albums",
							"host": ["{{baseUrl}}"],
							"path": ["artists", ":id", "albums"],
							"variable": [{ "key": "id", "value": "" }]
						}
					}
				}
			]
		},
		{
			"name": "Albums",
			"item": [
				{
					"name": "List Albums",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/albums?page=1&pageSize=20",
							"host": ["{{baseUrl}}"],
							"path": ["albums"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "pageSize", "value": "20" }
							]
						}
					}
				},
				{
					"name": "Get Album by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/albums/:id",
							"host": ["{{baseUrl}}"],
							"path": ["albums", ":id"],
							"variable": [{ "key": "id", "value": "" }]
						}
					}
				}
			]
		},
		{
			"name": "Playlists",
			"item": [
				{
					"name": "List My Playlists",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/playlists",
							"host": ["{{baseUrl}}"],
							"path": ["playlists"]
						}
					}
				},
				{
					"name": "Create Playlist",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"My Playlist\",\n  \"description\": \"My favorite songs\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/playlists",
							"host": ["{{baseUrl}}"],
							"path": ["playlists"]
						}
					}
				},
				{
					"name": "Delete Playlist",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/playlists/:id",
							"host": ["{{baseUrl}}"],
							"path": ["playlists", ":id"],
							"variable": [{ "key": "id", "value": "" }]
						}
					}
				},
				{
					"name": "Add Song to Playlist",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"songId\": \"song-id-here\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/playlists/:id/songs",
							"host": ["{{baseUrl}}"],
							"path": ["playlists", ":id", "songs"],
							"variable": [{ "key": "id", "value": "" }]
						}
					}
				},
				{
					"name": "Remove Song from Playlist",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/playlists/:id/songs/:songId",
							"host": ["{{baseUrl}}"],
							"path": ["playlists", ":id", "songs", ":songId"],
							"variable": [
								{ "key": "id", "value": "" },
								{ "key": "songId", "value": "" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Admin",
			"item": [
				{
					"name": "Set Admin Claim",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/admin/set-admin/:uid",
							"host": ["{{baseUrl}}"],
							"path": ["admin", "set-admin", ":uid"],
							"variable": [{ "key": "uid", "value": "" }]
						},
						"description": "⚠️ No auth guard — sets admin: true custom claim on a Firebase user"
					}
				}
			]
		}
	]
}
