{
	"info": {
		"name": "Music App API",
		"description": "NestJS Music API with Firebase, YouTube, and Gemini AI",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://music-app-server-lupbg4y2ha-uc.a.run.app",
			"type": "string"
		},
		{
			"key": "firebaseToken",
			"value": "",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{firebaseToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Songs",
			"item": [
				{
					"name": "List Songs",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs?page=1&pageSize=20",
							"host": ["{{baseUrl}}"],
							"path": ["songs"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "pageSize", "value": "20" }
							]
						}
					}
				},
				{
					"name": "Get Song by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/:id",
							"host": ["{{baseUrl}}"],
							"path": ["songs", ":id"],
							"variable": [{ "key": "id", "value": "" }]
						}
					}
				},
				{
					"name": "Search YouTube (simple)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/search-youtube?query=bad bunny",
							"host": ["{{baseUrl}}"],
							"path": ["songs", "search-youtube"],
							"query": [{ "key": "query", "value": "bad bunny" }]
						},
						"description": "Simple artist/song name search"
					}
				},
				{
					"name": "Search YouTube (natural language)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/search-youtube?query=sad reggaeton songs",
							"host": ["{{baseUrl}}"],
							"path": ["songs", "search-youtube"],
							"query": [{ "key": "query", "value": "sad reggaeton songs" }]
						},
						"description": "Natural language query — Gemini extracts genre/mood/tags"
					}
				},
				{
					"name": "Trending Music",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/trending?country=EC&limit=50",
							"host": ["{{baseUrl}}"],
							"path": ["songs", "trending"],
							"query": [
								{ "key": "country", "value": "EC" },
								{ "key": "limit", "value": "50" }
							]
						},
						"description": "Trending music by country code (cached 6h)"
					}
				},
				{
					"name": "All Searches",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/searches",
							"host": ["{{baseUrl}}"],
							"path": ["songs", "searches"]
						},
						"description": "Get all search queries ordered by popularity"
					}
				},
				{
					"name": "Generate Playlist from Song",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/:id/generate-playlist?limit=30",
							"host": ["{{baseUrl}}"],
							"path": ["songs", ":id", "generate-playlist"],
							"query": [
								{ "key": "limit", "value": "30" },
								{ "key": "search", "value": "", "disabled": true }
							],
							"variable": [{ "key": "id", "value": "" }]
						},
						"description": "AI-generated playlist based on a seed song. Optional search param for mood/vibe context."
					}
				},
				{
					"name": "Refresh Song Metadata",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/songs/:id/refresh-metadata",
							"host": ["{{baseUrl}}"],
							"path": ["songs", ":id", "refresh-metadata"],
							"variable": [{ "key": "id", "value": "" }]
						},
						"description": "Refresh Last.fm metadata (genres, tags, album art, listeners)"
					}
				},
				{
					"name": "Save Stream URL",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"streamUrl\": \"https://rr2---sn-xxx.googlevideo.com/videoplayback?...\",\n  \"expiresAt\": \"2026-04-28T04:00:00.000Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/songs/:id/stream-url",
							"host": ["{{baseUrl}}"],
							"path": ["songs", ":id", "stream-url"],
							"variable": [{ "key": "id", "value": "" }]
						},
						"description": "Save YouTube audio stream URL resolved by the client. Stored on song doc, returned in responses until expired."
					}
				},
				{
					"name": "Save Mix Stream URL",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"streamUrl\": \"https://rr2---sn-xxx.googlevideo.com/videoplayback?...\",\n  \"expiresAt\": \"2026-04-28T04:00:00.000Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/songs/mixes/:youtubeId/stream-url",
							"host": ["{{baseUrl}}"],
							"path": ["songs", "mixes", ":youtubeId", "stream-url"],
							"variable": [{ "key": "youtubeId", "value": "" }]
						},
						"description": "Save YouTube audio stream URL for a mix. Stored in mixes/{youtubeId} Firestore collection."
					}
				}
			]
		},
		{
			"name": "Artists",
