						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/me",
							"host": ["{{baseUrl}}"],
							"path": ["users", "me"]
						},
						"description": "Returns uid, likedSongs, downloadedSongs"
					}
				},
				{
					"name": "Get Liked Songs",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
