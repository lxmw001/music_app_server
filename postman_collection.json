							"host": ["{{baseUrl}}"],
							"path": ["users", "me", "liked-songs"]
						}
					}
				},
				{
					"name": "Is Song Liked",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/me/liked-songs/:songId",
							"host": ["{{baseUrl}}"],
							"path": ["users", "me", "liked-songs", ":songId"],
							"variable": [{ "key": "songId", "value": "" }]
						}
					}
				},
				{
					"name": "Like Song",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/me/liked-songs/:songId",
							"host": ["{{baseUrl}}"],
							"path": ["users", "me", "liked-songs", ":songId"],
							"variable": [{ "key": "songId", "value": "" }]
						}
					}
				},
				{
					"name": "Unlike Song",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/me/liked-songs/:songId",
							"host": ["{{baseUrl}}"],
							"path": ["users", "me", "liked-songs", ":songId"],
							"variable": [{ "key": "songId", "value": "" }]
						}
					}
				},
