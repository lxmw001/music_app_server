		{
			"name": "Vibe (Fast Mode)",
			"item": [
				{
					"name": "Generate Vibe Queries",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vibeId\": \"chill\",\n  \"subCategory\": \"lofi\",\n  \"genres\": [\"hip-hop\", \"jazz\"],\n  \"birthYear\": 1995,\n  \"localTime\": \"22:00\",\n  \"dayOfWeek\": \"Friday\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/vibe/generate",
							"host": ["{{baseUrl}}"],
							"path": ["vibe", "generate"]
						},
						"description": "Premium only (isPremium or admin). Generates YouTube search queries from a vibe/mood context via Gemini."
					}
				}
			]
		},
		{
			"name": "Admin",
			"item": [
				{
					"name": "Set Admin Claim",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/admin/set-admin/:uid",
							"host": ["{{baseUrl}}"],
							"path": ["admin", "set-admin", ":uid"],
							"variable": [{ "key": "uid", "value": "" }]
						},
						"description": "⚠️ No auth guard — sets admin: true custom claim on a Firebase user"
					}
				},
				{
					"name": "Grant Permission",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"permission\": \"offline_play\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/admin/users/:uid/permissions",
							"host": ["{{baseUrl}}"],
							"path": ["admin", "users", ":uid", "permissions"],
							"variable": [{ "key": "uid", "value": "" }]
						},
						"description": "Available permissions: offline_play, suggest_playlists"
					}
				},
				{
					"name": "Revoke Permission",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/admin/users/:uid/permissions/:permission",
							"host": ["{{baseUrl}}"],
							"path": ["admin", "users", ":uid", "permissions", ":permission"],
							"variable": [
								{ "key": "uid", "value": "" },
								{ "key": "permission", "value": "offline_play" }
							]
						}
					}
				},
				{
					"name": "Backfill Video Titles",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/admin/backfill-video-titles",
							"host": ["{{baseUrl}}"],
							"path": ["admin", "backfill-video-titles"]
						},
						"description": "One-time migration: backfill videoTitle for songs missing the field"
					}
				}
			]
		}
	]
}
